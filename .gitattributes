# Normalize line endings to LF on commit, LF on checkout
* text=auto eol=lf

# Explicitly LF for source files
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css  text eol=lf

# Binary — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
